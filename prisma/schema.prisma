datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMINISTRATOR
  MANAGER
  USER
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  AT_RISK
  DELAYED
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  BACKLOG
  TODO
  DOING
  REVIEW
  DONE
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  role         Role          @default(USER)
  avatarUrl    String?
  productivity Float         @default(1.0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  projects     Project[]     @relation("ProjectResponsible")
  tasks        Task[]        @relation("TaskResponsible")
  comments     Comment[]
  activityLogs ActivityLog[]
  notifications Notification[]

  @@map("users")
}

model Project {
  id              String        @id @default(uuid())
  name            String
  code            String        @unique
  description     String?
  client          String?
  responsibleId   String
  responsible     User          @relation("ProjectResponsible", fields: [responsibleId], references: [id])
  startDate       DateTime
  endDate         DateTime
  status          ProjectStatus @default(NOT_STARTED)
  priority        Priority      @default(MEDIUM)
  progress        Float         @default(0.0) // 0 to 100
  color           String        @default("green") // verde, amarelo, vermelho, azul, cinza
  tags            Tag[]
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tasks           Task[]
  activityLogs    ActivityLog[]

  @@map("projects")
}

model Task {
  id              String        @id @default(uuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  responsibleId   String
  responsible     User          @relation("TaskResponsible", fields: [responsibleId], references: [id])
  startDate       DateTime
  endDate         DateTime
  status          TaskStatus    @default(TODO)
  priority        Priority      @default(MEDIUM)
  dependencies    String        @default("[]") // JSON string representation of dependent Task IDs
  checklist       String        @default("[]") // JSON string representation of Checklist items
  attachments     Attachment[]
  comments        Comment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  activityLogs    ActivityLog[]

  @@map("tasks")
}

model Comment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@map("comments")
}

model Attachment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName  String
  fileSize  Int
  fileUrl   String
  createdAt DateTime @default(now())

  @@map("attachments")
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  projects  Project[]

  @@map("tags")
}

model ActivityLog {
  id        String   @id @default(uuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // e.g. "task_created", "status_changed", "project_updated"
  details   String   // JSON text or descriptive message
  createdAt DateTime @default(now())

  @@map("activity_logs")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  type      String   // info, warning, success, error
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}
